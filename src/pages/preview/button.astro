---
import '@atomchat.io/tokens/css';
import '@atomchat.io/css';
import { Button } from '@atomchat.io/components-astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Button Preview</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: var(--font-body, system-ui, sans-serif);
      background: #fff;
      color: var(--fg-default, #18181b);
    }

    .preview {
      padding: 1.5rem;
    }

    /* ── Controls ── */
    .preview__controls {
      display: flex;
      flex-wrap: wrap;
      gap: 1.25rem;
      padding: 1rem 0 1.25rem;
      border-bottom: 1px solid #e5e7eb;
      margin-bottom: 1.5rem;
    }

    .preview__group {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    .preview__group-label {
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #6b7280;
      line-height: 1;
    }

    .preview__chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }

    .preview__chip {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.625rem;
      font-size: 0.75rem;
      font-weight: 500;
      line-height: 1.4;
      border-radius: 100px;
      border: 1px solid #d1d5db;
      background: #fff;
      color: #374151;
      cursor: pointer;
      transition: all 150ms ease;
      user-select: none;
      white-space: nowrap;
    }

    .preview__chip:hover {
      border-color: #9ca3af;
      background: #f3f4f6;
    }

    .preview__chip--active {
      background: #18181b;
      border-color: #18181b;
      color: #fff;
    }

    .preview__chip--active:hover {
      background: #27272a;
      border-color: #27272a;
    }

    /* ── Stage ── */
    .preview__stage {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .preview__row {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .preview__row-label {
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #6b7280;
      min-width: 5rem;
      flex-shrink: 0;
    }

    .preview__items {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .preview__section-title {
      font-size: 0.8125rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #6b7280;
      margin: 0.5rem 0 0;
      padding-top: 1rem;
      border-top: 1px solid #f3f4f6;
    }

    .preview__section-title:first-child {
      border-top: none;
      padding-top: 0;
      margin-top: 0;
    }

    /* Hidden by filter */
    [data-section][hidden] {
      display: none;
    }

    @media (max-width: 640px) {
      .preview__row {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
      }
    }
  </style>
</head>
<body>
  <div class="preview" id="button-preview">
    <!-- Controls -->
    <div class="preview__controls">
      <div class="preview__group" data-control="view">
        <span class="preview__group-label">View</span>
        <div class="preview__chips">
          <button class="preview__chip preview__chip--active" data-value="variants" type="button">Variants</button>
          <button class="preview__chip" data-value="sizes" type="button">Sizes</button>
          <button class="preview__chip" data-value="states" type="button">States</button>
          <button class="preview__chip" data-value="icons" type="button">Icons</button>
        </div>
      </div>
    </div>

    <!-- Stage -->
    <div class="preview__stage">

      <!-- ═══ VARIANTS ═══ -->
      <div data-section="variants">
        <div class="preview__row">
          <span class="preview__row-label">Primary</span>
          <div class="preview__items">
            <Button variant="Primary" size="m">Primary</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">Secondary</span>
          <div class="preview__items">
            <Button variant="Secondary" size="m">Secondary</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">Tertiary</span>
          <div class="preview__items">
            <Button variant="Tertiary" size="m">Tertiary</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">Dest. Primary</span>
          <div class="preview__items">
            <Button variant="Destructive Primary" size="m">Destructive</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">Dest. Secondary</span>
          <div class="preview__items">
            <Button variant="Destructive Secondary" size="m">Destructive</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">Dest. Tertiary</span>
          <div class="preview__items">
            <Button variant="Destructive Tertiary" size="m">Destructive</Button>
          </div>
        </div>
      </div>

      <!-- ═══ SIZES ═══ -->
      <div data-section="sizes" hidden>
        <div class="preview__row">
          <span class="preview__row-label">XS</span>
          <div class="preview__items">
            <Button variant="Primary" size="xs">Extra Small</Button>
            <Button variant="Secondary" size="xs">Extra Small</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">S</span>
          <div class="preview__items">
            <Button variant="Primary" size="s">Small</Button>
            <Button variant="Secondary" size="s">Small</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">M</span>
          <div class="preview__items">
            <Button variant="Primary" size="m">Medium</Button>
            <Button variant="Secondary" size="m">Medium</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">L</span>
          <div class="preview__items">
            <Button variant="Primary" size="l">Large</Button>
            <Button variant="Secondary" size="l">Large</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">XL</span>
          <div class="preview__items">
            <Button variant="Primary" size="xl">Extra Large</Button>
            <Button variant="Secondary" size="xl">Extra Large</Button>
          </div>
        </div>
      </div>

      <!-- ═══ STATES ═══ -->
      <div data-section="states" hidden>
        <div class="preview__row">
          <span class="preview__row-label">Enabled</span>
          <div class="preview__items">
            <Button variant="Primary" size="m">Primary</Button>
            <Button variant="Secondary" size="m">Secondary</Button>
            <Button variant="Tertiary" size="m">Tertiary</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">Disabled</span>
          <div class="preview__items">
            <Button variant="Primary" size="m" disabled>Primary</Button>
            <Button variant="Secondary" size="m" disabled>Secondary</Button>
            <Button variant="Tertiary" size="m" disabled>Tertiary</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">Loading</span>
          <div class="preview__items">
            <Button variant="Primary" size="m" loading>Primary</Button>
            <Button variant="Secondary" size="m" loading>Secondary</Button>
            <Button variant="Tertiary" size="m" loading>Tertiary</Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">As Link</span>
          <div class="preview__items">
            <Button variant="Primary" size="m" href="#">Link Button</Button>
            <Button variant="Secondary" size="m" href="#">Link Button</Button>
          </div>
        </div>
      </div>

      <!-- ═══ ICONS ═══ -->
      <div data-section="icons" hidden>
        <div class="preview__row">
          <span class="preview__row-label">Icon Left</span>
          <div class="preview__items">
            <Button variant="Primary" size="m">
              <svg slot="icon-left" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
              </svg>
              Add Item
            </Button>
            <Button variant="Secondary" size="m">
              <svg slot="icon-left" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <path d="M11.251.068a.5.5 0 0 1 .227.58L9.677 6.5H13a.5.5 0 0 1 .364.843l-8 8.5a.5.5 0 0 1-.842-.49L6.323 9.5H3a.5.5 0 0 1-.364-.843l8-8.5a.5.5 0 0 1 .615-.09z"/>
              </svg>
              Quick Action
            </Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">Icon Right</span>
          <div class="preview__items">
            <Button variant="Primary" size="m">
              Continue
              <svg slot="icon-right" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
              </svg>
            </Button>
            <Button variant="Secondary" size="m">
              Download
              <svg slot="icon-right" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
              </svg>
            </Button>
          </div>
        </div>
        <div class="preview__row">
          <span class="preview__row-label">Both Icons</span>
          <div class="preview__items">
            <Button variant="Primary" size="m">
              <svg slot="icon-left" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z"/>
              </svg>
              Verified Action
              <svg slot="icon-right" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
              </svg>
            </Button>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    import { initAllAnimations } from '@atomchat.io/animations';

    const preview = document.getElementById('button-preview')!;
    const chips = preview.querySelectorAll<HTMLButtonElement>('.preview__chip');
    const sections = preview.querySelectorAll<HTMLElement>('[data-section]');

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const view = chip.dataset.value!;

        chips.forEach((c) => c.classList.remove('preview__chip--active'));
        chip.classList.add('preview__chip--active');

        sections.forEach((s) => {
          s.hidden = s.dataset.section !== view;
        });
      });
    });

    initAllAnimations();
  </script>
</body>
</html>
