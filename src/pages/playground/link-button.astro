---
import '@atomchat.io/tokens/css';
import '@atomchat.io/css';
import { LinkButton } from '@atomchat.io/components-astro';
import { ArrowRight, ExternalLink, Download, ChevronRight, Plus, Sparkles } from '@lucide/astro';

const title = 'LinkButton Playground';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style>
    /* Fix: Override link-button opacity tokens */
    :root {
      --opacity-0: 0;
    }

    body {
      font-family: var(--font-body, system-ui, sans-serif);
      padding: 2rem;
      background: var(--bg-default, #fff);
      color: var(--fg-default, #000);
    }
    .playground {
      max-width: 1200px;
      margin: 0 auto;
    }
    .section {
      margin-bottom: 3rem;
      padding: 2rem;
      background: var(--bg-subtle, #f9f9f9);
      border-radius: 8px;
    }
    .section h2 {
      margin-top: 0;
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
    }
    .section h3 {
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-size: 1.25rem;
    }
    .link-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      align-items: flex-start;
    }
    .link-item {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .link-label {
      font-size: 0.75rem;
      color: var(--fg-muted, #666);
    }
  </style>
</head>
<body>
  <div class="playground">
    <h1>LinkButton Component Playground</h1>

    <div class="section">
      <h2>All Sizes</h2>
      <div class="link-grid">
        <div class="link-item">
          <LinkButton href="#" size="s">
            Small Link
          </LinkButton>
          <span class="link-label">Size S (Default)</span>
        </div>

        <div class="link-item">
          <LinkButton href="#" size="l">
            Large Link
          </LinkButton>
          <span class="link-label">Size L</span>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>With Icons</h2>

      <h3>Icon Right (Common Pattern)</h3>
      <div class="link-grid">
        <LinkButton href="#" size="s">
          Read more
          <ArrowRight slot="icon-right" size={16} />
        </LinkButton>

        <LinkButton href="#" size="l">
          View documentation
          <ChevronRight slot="icon-right" size={20} />
        </LinkButton>

        <LinkButton href="https://example.com" external size="s">
          External link
          <ExternalLink slot="icon-right" size={16} />
        </LinkButton>
      </div>

      <h3>Icon Left</h3>
      <div class="link-grid">
        <LinkButton href="#" size="s">
          <Download slot="icon-left" size={16} />
          Download file
        </LinkButton>

        <LinkButton href="#" size="l">
          <Plus slot="icon-left" size={20} />
          Add new item
        </LinkButton>

        <LinkButton href="#" size="s">
          <Sparkles slot="icon-left" size={16} />
          Discover features
        </LinkButton>
      </div>

      <h3>Both Icons</h3>
      <div class="link-grid">
        <LinkButton href="#" size="s">
          <Sparkles slot="icon-left" size={16} />
          Explore more
          <ArrowRight slot="icon-right" size={16} />
        </LinkButton>

        <LinkButton href="#" size="l">
          <Plus slot="icon-left" size={20} />
          Create project
          <ChevronRight slot="icon-right" size={20} />
        </LinkButton>
      </div>
    </div>

    <div class="section">
      <h2>States</h2>

      <h3>Disabled</h3>
      <p style="margin-bottom: 1rem; color: var(--fg-muted, #666); font-size: 0.875rem;">
        Disabled links are not clickable and have reduced opacity
      </p>
      <div class="link-grid">
        <LinkButton href="#" size="s" disabled>
          Disabled link
        </LinkButton>

        <LinkButton href="#" size="l" disabled>
          <Download slot="icon-left" size={20} />
          Disabled with icon
        </LinkButton>
      </div>

      <h3>Loading</h3>
      <p style="margin-bottom: 1rem; color: var(--fg-muted, #666); font-size: 0.875rem;">
        Loading state shows "Loading..." text with shimmer animation
      </p>
      <div class="link-grid">
        <LinkButton href="#" size="s" loading>
          Loading...
        </LinkButton>

        <LinkButton href="#" size="l" loading>
          Processing...
        </LinkButton>
      </div>
    </div>

    <div class="section">
      <h2>External Links</h2>
      <p style="margin-bottom: 1rem; color: var(--fg-muted, #666); font-size: 0.875rem;">
        External links open in new tab with rel="noopener noreferrer"
      </p>
      <div class="link-grid">
        <LinkButton href="https://github.com" external size="s">
          GitHub
          <ExternalLink slot="icon-right" size={16} />
        </LinkButton>

        <LinkButton href="https://npmjs.com" external size="s">
          npm Registry
          <ExternalLink slot="icon-right" size={16} />
        </LinkButton>

        <LinkButton href="https://docs.example.com" external size="l">
          Documentation
          <ExternalLink slot="icon-right" size={20} />
        </LinkButton>
      </div>
    </div>

    <div class="section">
      <h2>Common Use Cases</h2>

      <h3>Navigation Links</h3>
      <div class="link-grid">
        <LinkButton href="/getting-started" size="s">
          Getting started
          <ChevronRight slot="icon-right" size={16} />
        </LinkButton>

        <LinkButton href="/components" size="s">
          Components
          <ChevronRight slot="icon-right" size={16} />
        </LinkButton>

        <LinkButton href="/examples" size="s">
          Examples
          <ChevronRight slot="icon-right" size={16} />
        </LinkButton>
      </div>

      <h3>Call to Action</h3>
      <div class="link-grid">
        <LinkButton href="/docs" size="l">
          Read the documentation
          <ArrowRight slot="icon-right" size={20} />
        </LinkButton>

        <LinkButton href="/download" size="l">
          <Download slot="icon-left" size={20} />
          Download now
        </LinkButton>
      </div>
    </div>

    <p style="margin-top: 3rem; text-align: center; color: var(--fg-muted, #666);">
      <a href="#" onclick="history.back(); return false;" style="color: var(--fg-link, #0066cc); cursor: pointer;">← Back to Documentation</a>
    </p>
  </div>

  <script>
    import { initShimmerText } from '@atomchat.io/animations/loading';

    console.log('[DEBUG] LinkButton playground script loaded, readyState:', document.readyState);

    // Wait for DOM to be fully loaded
    if (document.readyState === 'loading') {
      console.log('[DEBUG] Waiting for DOMContentLoaded...');
      document.addEventListener('DOMContentLoaded', init);
    } else {
      console.log('[DEBUG] DOM already loaded, initializing now...');
      init();
    }

    function init() {
      console.log('[DEBUG] init() called');
      console.log('[DEBUG] LinkButton elements:', document.querySelectorAll('[data-link-button]').length);
      console.log('[DEBUG] Elements with [data-shimmer]:', document.querySelectorAll('[data-shimmer]').length);

      // Initialize shimmer animation for loading state
      console.log('[DEBUG] Calling initShimmerText()...');
      const cleanup = initShimmerText();
      console.log('[DEBUG] ✓ initShimmerText returned:', typeof cleanup);

      console.log('[DEBUG] ✅ All animations initialized successfully');
    }
  </script>
</body>
</html>
