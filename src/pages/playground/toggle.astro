---
import '@atomchat.io/tokens/css';
import '@atomchat.io/css';
import { Toggle } from '@atomchat.io/components-astro';

const title = 'Toggle Playground';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style>
    /* Fix: Override opacity tokens */
    :root {
      --opacity-0: 0;
    }

    body {
      font-family: var(--font-body, system-ui, sans-serif);
      padding: 2rem;
      background: var(--bg-default, #fff);
      color: var(--fg-default, #000);
    }
    .playground {
      max-width: 1200px;
      margin: 0 auto;
    }
    .section {
      margin-bottom: 3rem;
      padding: 2rem;
      background: var(--bg-subtle, #f9f9f9);
      border-radius: 8px;
    }
    .section h2 {
      margin-top: 0;
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
    }
    .section h3 {
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-size: 1.25rem;
    }
    .toggle-grid {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .toggle-group {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem;
      background: var(--bg-default, #fff);
      border-radius: 8px;
    }
    .group-label {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--fg-default, #000);
      margin-bottom: 0.5rem;
    }
    .size-comparison {
      display: flex;
      gap: 3rem;
      align-items: flex-start;
    }
    .toggle-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }
  </style>
</head>
<body>
  <div class="playground">
    <h1>Toggle Component Playground</h1>

    <div class="section">
      <h2>All Sizes</h2>

      <h3>Size S (Default)</h3>
      <div class="toggle-grid">
        <Toggle name="notifications-s" size="s">
          Enable notifications
        </Toggle>
        <Toggle name="dark-mode-s" size="s" checked>
          Dark mode
        </Toggle>
        <Toggle name="auto-save-s" size="s">
          Auto-save changes
        </Toggle>
      </div>

      <h3>Size M</h3>
      <div class="toggle-grid">
        <Toggle name="notifications-m" size="m">
          Enable notifications
        </Toggle>
        <Toggle name="dark-mode-m" size="m" checked>
          Dark mode
        </Toggle>
        <Toggle name="auto-save-m" size="m">
          Auto-save changes
        </Toggle>
      </div>
    </div>

    <div class="section">
      <h2>With Supportive Text</h2>
      <div class="toggle-grid">
        <Toggle
          name="notifications-support"
          size="s"
          supportiveText="Receive email notifications for new messages"
        >
          Email notifications
        </Toggle>
        <Toggle
          name="analytics-support"
          size="s"
          checked
          supportiveText="Help us improve by sharing anonymous usage data"
        >
          Analytics tracking
        </Toggle>
        <Toggle
          name="marketing-support"
          size="m"
          supportiveText="Receive updates about new features and promotions"
        >
          Marketing emails
        </Toggle>
        <Toggle
          name="beta-support"
          size="m"
          checked
          supportiveText="Get early access to new features before public release"
        >
          Beta features
        </Toggle>
      </div>
    </div>

    <div class="section">
      <h2>States</h2>

      <h3>Disabled</h3>
      <div class="toggle-grid">
        <Toggle name="disabled-off" size="s" disabled>
          Disabled (off)
        </Toggle>
        <Toggle name="disabled-on" size="s" checked disabled>
          Disabled (on)
        </Toggle>
        <Toggle
          name="disabled-support"
          size="m"
          disabled
          supportiveText="This feature is not available on your current plan"
        >
          Premium feature
        </Toggle>
      </div>

      <h3>Error State</h3>
      <div class="toggle-grid">
        <Toggle
          name="terms-error"
          size="s"
          error
          errorText="You must accept the terms and conditions to continue"
        >
          Accept terms and conditions
        </Toggle>
        <Toggle
          name="required-error"
          size="m"
          supportiveText="This setting is required for account security"
          error
          errorText="Two-factor authentication must be enabled"
        >
          Enable two-factor authentication
        </Toggle>
      </div>
    </div>

    <div class="section">
      <h2>Bare Toggle (No Label)</h2>
      <p style="margin-bottom: 1.5rem; color: var(--fg-muted, #666); font-size: 0.875rem;">
        Toggles without labels render as standalone controls
      </p>
      <div class="size-comparison">
        <div class="toggle-item">
          <Toggle name="bare-s-off" size="s" />
          <span style="font-size: 0.75rem; color: var(--fg-muted);">Size S (Off)</span>
        </div>
        <div class="toggle-item">
          <Toggle name="bare-s-on" size="s" checked />
          <span style="font-size: 0.75rem; color: var(--fg-muted);">Size S (On)</span>
        </div>
        <div class="toggle-item">
          <Toggle name="bare-m-off" size="m" />
          <span style="font-size: 0.75rem; color: var(--fg-muted);">Size M (Off)</span>
        </div>
        <div class="toggle-item">
          <Toggle name="bare-m-on" size="m" checked />
          <span style="font-size: 0.75rem; color: var(--fg-muted);">Size M (On)</span>
        </div>
        <div class="toggle-item">
          <Toggle name="bare-disabled" size="s" disabled />
          <span style="font-size: 0.75rem; color: var(--fg-muted);">Disabled</span>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Common Use Cases</h2>

      <h3>Privacy Settings</h3>
      <div class="toggle-group">
        <span class="group-label">Privacy & Security</span>
        <Toggle
          name="profile-visibility"
          size="s"
          checked
          supportiveText="Make your profile visible to other users"
        >
          Public profile
        </Toggle>
        <Toggle
          name="online-status"
          size="s"
          supportiveText="Show your online status to others"
        >
          Show online status
        </Toggle>
        <Toggle
          name="read-receipts"
          size="s"
          checked
          supportiveText="Let others know when you've read their messages"
        >
          Read receipts
        </Toggle>
        <Toggle
          name="location-sharing"
          size="s"
          supportiveText="Share your location with trusted contacts"
        >
          Location sharing
        </Toggle>
      </div>

      <h3>Notification Preferences</h3>
      <div class="toggle-group">
        <span class="group-label">Notification Settings</span>
        <Toggle
          name="push-notifications"
          size="m"
          checked
          supportiveText="Receive push notifications on your device"
        >
          Push notifications
        </Toggle>
        <Toggle
          name="email-digest"
          size="m"
          supportiveText="Get a daily summary of your activity"
        >
          Daily email digest
        </Toggle>
        <Toggle
          name="sound-notifications"
          size="m"
          checked
          supportiveText="Play sound when you receive a notification"
        >
          Sound alerts
        </Toggle>
      </div>

      <h3>Feature Toggles</h3>
      <div class="toggle-group">
        <span class="group-label">Experimental Features</span>
        <Toggle
          name="new-editor"
          size="s"
          supportiveText="Try our new code editor interface"
        >
          New editor (Beta)
        </Toggle>
        <Toggle
          name="ai-suggestions"
          size="s"
          checked
          supportiveText="Get AI-powered code suggestions while typing"
        >
          AI code completion
        </Toggle>
        <Toggle
          name="advanced-mode"
          size="s"
          supportiveText="Access advanced settings and features"
        >
          Advanced mode
        </Toggle>
      </div>

      <h3>Accessibility Settings</h3>
      <div class="toggle-group">
        <span class="group-label">Accessibility</span>
        <Toggle
          name="high-contrast"
          size="m"
          supportiveText="Increase contrast for better visibility"
        >
          High contrast mode
        </Toggle>
        <Toggle
          name="reduced-motion"
          size="m"
          supportiveText="Minimize animations and transitions"
        >
          Reduce motion
        </Toggle>
        <Toggle
          name="screen-reader"
          size="m"
          checked
          supportiveText="Optimize interface for screen readers"
        >
          Screen reader support
        </Toggle>
      </div>
    </div>

    <p style="margin-top: 3rem; text-align: center; color: var(--fg-muted, #666);">
      <a href="#" onclick="history.back(); return false;" style="color: var(--fg-link, #0066cc); cursor: pointer;">← Back to Documentation</a>
    </p>
  </div>

  <script>
    console.log('[DEBUG] Toggle playground script loaded');
    console.log('[DEBUG] Toggle elements:', document.querySelectorAll('[data-toggle]').length);
    console.log('[DEBUG] Toggle track elements:', document.querySelectorAll('[data-toggle-track]').length);
    console.log('[DEBUG] Toggle knob elements:', document.querySelectorAll('[data-toggle-knob]').length);
  </script>
</body>
</html>
