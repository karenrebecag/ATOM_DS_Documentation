---
import '@atomchat.io/tokens/css';
import '@atomchat.io/css';
import { Avatar } from '@atomchat.io/components-astro';

const title = 'Avatar Playground';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style>
    body {
      font-family: var(--font-body, system-ui, sans-serif);
      padding: 2rem;
      background: var(--bg-default, #fff);
      color: var(--fg-default, #000);
    }
    .playground {
      max-width: 1200px;
      margin: 0 auto;
    }
    .section {
      margin-bottom: 3rem;
      padding: 2rem;
      background: var(--bg-subtle, #f9f9f9);
      border-radius: 8px;
    }
    .section h2 {
      margin-top: 0;
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
    }
    .section h3 {
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-size: 1.25rem;
    }
    .avatar-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      align-items: center;
    }
  </style>
</head>
<body>
  <div class="playground">
    <h1>Avatar Component Playground</h1>

    <div class="section">
      <h2>All Sizes (Circle, Image)</h2>
      <div class="avatar-grid">
        <Avatar src="https://i.pravatar.cc/150?img=1" size="xs" shape="circle" />
        <Avatar src="https://i.pravatar.cc/150?img=2" size="s" shape="circle" />
        <Avatar src="https://i.pravatar.cc/150?img=3" size="m" shape="circle" />
        <Avatar src="https://i.pravatar.cc/150?img=4" size="l" shape="circle" />
      </div>
    </div>

    <div class="section">
      <h2>Shapes (Size M)</h2>
      <div class="avatar-grid">
        <div>
          <p style="margin-bottom: 0.5rem; font-size: 0.875rem; color: var(--fg-muted, #666);">Circle</p>
          <Avatar src="https://i.pravatar.cc/150?img=5" size="m" shape="circle" />
        </div>
        <div>
          <p style="margin-bottom: 0.5rem; font-size: 0.875rem; color: var(--fg-muted, #666);">Square</p>
          <Avatar src="https://i.pravatar.cc/150?img=6" size="m" shape="square" />
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Types</h2>

      <h3>Image (no border)</h3>
      <div class="avatar-grid">
        <Avatar src="https://i.pravatar.cc/150?img=7" size="m" type="image" shape="circle" />
        <Avatar src="https://i.pravatar.cc/150?img=8" size="m" type="image" shape="square" />
      </div>

      <h3>Image with Border</h3>
      <div class="avatar-grid">
        <Avatar src="https://i.pravatar.cc/150?img=9" size="m" type="image-border" shape="circle" />
        <Avatar src="https://i.pravatar.cc/150?img=10" size="m" type="image-border" shape="square" />
      </div>

      <h3>Initials</h3>
      <div class="avatar-grid">
        <Avatar size="m" type="initials" shape="circle">JD</Avatar>
        <Avatar size="m" type="initials" shape="square">AB</Avatar>
        <Avatar size="l" type="initials" shape="circle">KO</Avatar>
      </div>

      <h3>Icon</h3>
      <div class="avatar-grid">
        <Avatar size="m" type="icon" shape="circle">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/>
          </svg>
        </Avatar>
        <Avatar size="m" type="icon" shape="square">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/>
          </svg>
        </Avatar>
      </div>
    </div>

    <div class="section">
      <h2>With Badges</h2>

      <h3>Verified</h3>
      <div class="avatar-grid">
        <Avatar src="https://i.pravatar.cc/150?img=11" size="xs" type="image-border" shape="circle" badge="verified" />
        <Avatar src="https://i.pravatar.cc/150?img=12" size="s" type="image-border" shape="circle" badge="verified" />
        <Avatar src="https://i.pravatar.cc/150?img=13" size="m" type="image-border" shape="circle" badge="verified" />
        <Avatar src="https://i.pravatar.cc/150?img=14" size="l" type="image-border" shape="circle" badge="verified" />
      </div>

      <h3>Online</h3>
      <div class="avatar-grid">
        <Avatar src="https://i.pravatar.cc/150?img=15" size="xs" type="image-border" shape="circle" badge="online" />
        <Avatar src="https://i.pravatar.cc/150?img=16" size="s" type="image-border" shape="circle" badge="online" />
        <Avatar src="https://i.pravatar.cc/150?img=17" size="m" type="image-border" shape="circle" badge="online" />
        <Avatar src="https://i.pravatar.cc/150?img=18" size="l" type="image-border" shape="circle" badge="online" />
      </div>

      <h3>Offline</h3>
      <div class="avatar-grid">
        <Avatar src="https://i.pravatar.cc/150?img=19" size="xs" type="image-border" shape="circle" badge="offline" />
        <Avatar src="https://i.pravatar.cc/150?img=20" size="s" type="image-border" shape="circle" badge="offline" />
        <Avatar src="https://i.pravatar.cc/150?img=21" size="m" type="image-border" shape="circle" badge="offline" />
        <Avatar src="https://i.pravatar.cc/150?img=22" size="l" type="image-border" shape="circle" badge="offline" />
      </div>
    </div>

    <p style="margin-top: 3rem; text-align: center; color: var(--fg-muted, #666);">
      <a href="/" style="color: var(--fg-link, #0066cc);">← Back to Documentation</a>
    </p>
  </div>

  <script>
    import { initAllAnimations } from '@atomchat.io/animations';
    initAllAnimations();
  </script>
</body>
</html>
