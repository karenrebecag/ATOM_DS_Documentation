---
import { Code } from '@astrojs/starlight/components';
import { fetchComponentSource, createComponentSource, type Framework } from '../utils/fetchComponentSource';

interface Props {
  component: string;
  framework: Framework;
  version?: string;
  filePath?: string;
}

const { component, framework, version, filePath } = Astro.props;

let sourceCode: string | null = null;
let fetchError: string | null = null;

try {
  sourceCode = await fetchComponentSource({ component, framework, version, filePath });
} catch (e) {
  fetchError = e instanceof Error ? e.message : String(e);
}

const componentSource = sourceCode !== null
  ? createComponentSource(sourceCode, framework, component)
  : null;
---

{fetchError ? (
  <p style="font-size: 0.8rem; color: var(--sl-color-gray-3); font-style: italic; margin: 0.5rem 0;">
    Source unavailable for this framework.
  </p>
) : componentSource ? (
  <Code
    code={componentSource.content}
    lang={componentSource.language}
    title={componentSource.path}
  />
) : null}
