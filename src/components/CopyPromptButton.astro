---
/**
 * CopyPromptButton - Framework-aware AI prompt copy button
 *
 * DOCUMENTATION-ONLY COMPONENT (NOT PART OF DESIGN SYSTEM)
 * This is a hardcoded utility component specific to the ATOMDS documentation site.
 * It is NOT distributed as part of @atomchat.io packages.
 *
 * PURPOSE:
 * Displays a branded button that copies Claude AI prompts to clipboard.
 * Reads structured prompts from /src/promptsDocumentation/{componentName}.ts
 * and dynamically selects the appropriate prompt based on current framework
 * selection (Astro, React, Vue, Angular).
 *
 * USAGE CONTEXT:
 * - Embedded in component documentation pages (e.g., button.mdx, avatar.mdx)
 * - Syncs with FrameworkSwitcher to show framework-specific prompts
 * - Features animated gradient background via GrainyGradient component
 * - Provides one-click prompt copying for Claude Code users
 *
 * WHY HARDCODED:
 * This component is tightly coupled to the documentation structure and
 * prompt file conventions. It's not a reusable design system component,
 * but rather infrastructure for the documentation experience.
 */

import GrainyGradient from './GrainyGradient.astro'

interface Props {
  component: string          // Component name (e.g., "button")
  framework?: string          // Initial framework (default: "astro")
  variant?: 'primary' | 'secondary'
}

const { component, framework = 'astro', variant = 'primary' } = Astro.props

// Import structured prompts
let prompts: Record<string, any> = {}
let promptsJson = '{}'

try {
  const promptModule = await import(`../promptsDocumentation/${component}.ts`)
  prompts = promptModule[`${component}Prompts`] || {}
  promptsJson = JSON.stringify(prompts)
} catch (error) {
  // Fallback to placeholder prompts when component-specific prompts don't exist
  const placeholderModule = await import(`../promptsDocumentation/_placeholder.ts`)
  prompts = placeholderModule.placeholderPrompts || {}
  promptsJson = JSON.stringify(prompts)
}
---

<div class="copy-prompt-wrapper not-content">
  <button
    aria-label="Copy component prompt to clipboard"
    data-copy-prompt-button=""
    data-component={component}
    data-prompts={promptsJson}
    data-initial-framework={framework}
    class={`copy-prompt-button copy-prompt-button--${variant}`}
  >
    <div class="copy-prompt-button__gradient-bg">
      <GrainyGradient
        color1="#510147"
        color2="#715abf"
        color3="#715abf"
        timeSpeed={0.15}
        colorBalance={0}
        warpStrength={1}
        warpFrequency={2}
        warpSpeed={1}
        warpAmplitude={20}
        grainAmount={0.1}
        grainScale={2}
        contrast={1.5}
        zoom={1}
      />
    </div>
    <div class="copy-prompt-button__content">
      <div class="copy-prompt-icon__wrap">
        <img src="/cursor_dark.svg" alt="" width="100%" />
      </div>
      <div class="copy-prompt-text__wrap">
        <span class="copy-prompt-text__el">Click to Build it with AI</span>
        <span class="copy-prompt-text__el">Click to copy</span>
        <span class="copy-prompt-text__el">Copied to clipboard!</span>
      </div>
    </div>
  </button>
</div>

<style>
.copy-prompt-wrapper {
  display: flex;
  flex-flow: column;
  justify-content: center;
  align-items: stretch;
  gap: 0;
  margin: 0;
  margin-top: 0;
  padding: 0;
  width: 100%;
}

/* Override Starlight markdown content spacing */
:global(.sl-markdown-content) .copy-prompt-wrapper {
  margin-top: 0;
}

.copy-prompt-button {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  padding: 0.25em 0;
  margin: 20px 0;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: var(--sl-font);
  background: transparent;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(113, 90, 191, 0.4);
}

.copy-prompt-button::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 0.5em;
  padding: px;

  pointer-events: none;
  z-index: 2;
}

.copy-prompt-button__gradient-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.copy-prompt-button__content {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  gap: 0.75em;
  padding: 0.75em 1em 0.75em 0.75em;
}

.copy-prompt-button--primary::before {
  background: linear-gradient(135deg, rgba(255, 159, 252, 0.4), transparent);
}

.copy-prompt-button--secondary::before {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), transparent);
}

.copy-prompt-button:focus {
  outline-offset: 0px;
  outline: 2px solid rgb(172, 155, 255) ;
}

.copy-prompt-button:focus-visible {
  outline-offset: 4px;
  border-style: none;
  outline: 2px solid rgb(172, 155, 255);
}

.copy-prompt-icon__wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 2.5em;
  height: 2.5em;
  padding: 0.5em;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(8px);
  color: #fff;
  border-radius: 0.375em;
  transition: all 0.2s ease;
}

.copy-prompt-text__wrap {
  display: flex;
  flex-flow: column;
  justify-content: flex-start;
  align-items: center;
  height: 1.2em;
  font-size: 1em;
  line-height: 1.2;
  overflow: hidden;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  margin: 0;
  padding: 0;
}

.copy-prompt-text__el {
  white-space: nowrap;
  font-size: 1em;
  font-weight: 700;
  margin: 0;
  padding: 0;
  transition: transform 0.45s cubic-bezier(0.65, 0, 0, 1);
}

/* Hover styling */
@media (hover: hover) {
  .copy-prompt-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(113, 90, 191, 0.4);
  }

  .copy-prompt-button:hover::before {
    background: linear-gradient(135deg, rgba(255, 159, 252, 0.6), transparent);
  }

  .copy-prompt-button:hover .copy-prompt-icon__wrap {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.05);
  }

  .copy-prompt-button:hover .copy-prompt-text__el {
    transform: translateY(-100%);
  }
}

/* Keyboard focus styling */
.copy-prompt-button:focus .copy-prompt-icon__wrap {
  background: rgba(255, 255, 255, 0.25);
}

.copy-prompt-button:focus .copy-prompt-text__el {
  transform: translateY(-100%);
}

/* 'Copied' state */
[data-copy-prompt-button="copied"] .copy-prompt-icon__wrap {
  background: rgba(120, 115, 218, 0.6) !important;
}

[data-copy-prompt-button="copied"] .copy-prompt-text__el {
  transform: translateY(-200%) !important;
}

@media screen and (max-width: 991px) {
  .copy-prompt-wrapper {
    font-size: 0.9em;
  }
}

@media screen and (max-width: 479px) {
  .copy-prompt-text__wrap {
    font-size: 0.85em;
  }
}
</style>

<script>
/**
 * Framework-Aware Clipboard Handler
 * Reads current framework from localStorage or data attribute
 * Copies the appropriate framework-specific prompt
 */
function initCopyPromptClipboard() {
  const buttons = document.querySelectorAll('[data-copy-prompt-button]')
  if (!buttons.length) return

  const getCurrentFramework = (button: HTMLButtonElement): string => {
    // Priority 1: Detect active Starlight tab (for <Tabs> component)
    // Find the closest .tablist-wrapper or starlight-tabs container
    let container = button.closest('.tablist-wrapper') ||
                    button.closest('[data-tabs]') ||
                    button.parentElement

    // Look for the parent that contains the tablist
    while (container && !container.querySelector('[role="tablist"]')) {
      container = container.parentElement
    }

    if (container) {
      const activeTab = container.querySelector('[role="tab"][aria-selected="true"]')
      if (activeTab) {
        const tabLabel = activeTab.textContent?.trim().toLowerCase()
        // Map tab labels to framework names
        const frameworkMap: Record<string, string> = {
          'astro': 'astro',
          'react': 'react',
          'vue': 'vue',
          'angular': 'angular',
          'next.js': 'nextjs',
          'nextjs': 'nextjs'
        }
        if (tabLabel && frameworkMap[tabLabel]) {
          console.log('Detected framework from tab:', frameworkMap[tabLabel])
          return frameworkMap[tabLabel]
        }
      }
    }

    // Priority 2: Framework selector state (localStorage)
    const storedFramework = localStorage.getItem('preferred-framework')
    if (storedFramework) {
      console.log('Using stored framework:', storedFramework)
      return storedFramework
    }

    // Priority 3: Active framework from FrameworkSwitcher
    const activeFrameworkTab = document.querySelector('[data-framework][data-active="true"]')
    if (activeFrameworkTab) {
      const framework = activeFrameworkTab.getAttribute('data-framework')
      if (framework) {
        console.log('Using FrameworkSwitcher framework:', framework)
        return framework
      }
    }

    // Priority 4: Initial framework from button data attribute
    const initialFramework = button.getAttribute('data-initial-framework')
    if (initialFramework) {
      console.log('Using initial framework:', initialFramework)
      return initialFramework
    }

    // Fallback: astro
    console.log('Using fallback framework: astro')
    return 'astro'
  }

  const copyPrompt = (button: HTMLButtonElement) => {
    try {
      const promptsJson = button.getAttribute('data-prompts')
      if (!promptsJson) {
        console.error('No prompts data found')
        return
      }

      const prompts = JSON.parse(promptsJson)
      const currentFramework = getCurrentFramework(button)
      const promptData = prompts[currentFramework]

      if (!promptData || !promptData.prompt) {
        console.error(`No prompt found for framework: ${currentFramework}`)
        return
      }

      navigator.clipboard.writeText(promptData.prompt).then(() => {
        button.setAttribute('data-copy-prompt-button', 'copied')
        button.setAttribute('aria-label', `${promptData.title || 'Prompt'} copied to clipboard!`)

        // Reset after 3 seconds
        setTimeout(() => {
          button.removeAttribute('data-copy-prompt-button')
          button.setAttribute('aria-label', 'Copy component prompt to clipboard')
        }, 3000)
      }).catch((err) => {
        console.error('Failed to copy prompt:', err)
      })
    } catch (error) {
      console.error('Error copying prompt:', error)
    }
  }

  const handleInteraction = (e: Event) => {
    const target = e.currentTarget as HTMLButtonElement
    if (
      e.type === 'click' ||
      (e.type === 'keydown' && ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' '))
    ) {
      e.preventDefault()
      copyPrompt(target)
    }
  }

  buttons.forEach((button) => {
    const btn = button as HTMLButtonElement
    btn.addEventListener('click', handleInteraction)
    btn.addEventListener('keydown', handleInteraction)
    btn.addEventListener('mouseleave', () => {
      // Don't reset if in "copied" state
      if (btn.getAttribute('data-copy-prompt-button') !== 'copied') {
        btn.removeAttribute('data-copy-prompt-button')
      }
      btn.blur()
    })
    btn.addEventListener('blur', () => {
      // Don't reset if in "copied" state
      if (btn.getAttribute('data-copy-prompt-button') !== 'copied') {
        btn.removeAttribute('data-copy-prompt-button')
      }
    })
  })
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', () => {
  initCopyPromptClipboard()
})

// Reinitialize on Astro page transitions
document.addEventListener('astro:page-load', () => {
  initCopyPromptClipboard()
})

// Listen for framework selector changes
window.addEventListener('storage', (e) => {
  if (e.key === 'preferred-framework') {
    // Framework changed, buttons will read new value on next click
    console.log('Framework changed to:', e.newValue)
  }
})
</script>
